generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum RegistrationStatus {
  PENDING_PAYMENT
  RECEIPT_UPLOADED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum SessionType {
  HALF_DAY
  FULL_DAY
}

enum Gender {
  MALE
  FEMALE
}

enum TShirtSize {
  YOUTH_S
  YOUTH_M
  YOUTH_L
  ADULT_S
  ADULT_M
  ADULT_L
  ADULT_XL
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         Role       @default(STAFF)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]
}

model Registration {
  id              String             @id @default(cuid())
  referenceNumber String             @unique
  status          RegistrationStatus @default(PENDING_PAYMENT)
  session         SessionType
  amount          Decimal
  receiptUrl      String?
  adminNote       String?
  rejectionReason String?
  idempotencyKey  String?            @unique
  campYear        Int                @default(2026)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  camper      Camper?
  parent      Parent?
  medicalInfo MedicalInfo?
  waiver      Waiver?
  auditLogs   AuditLog[]

  @@index([status])
  @@index([session])
}

model Camper {
  id             String       @id @default(cuid())
  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  age            Int
  gender         Gender
  gradeLevel     String
  schoolName     String
  tShirtSize     TShirtSize
  height         Int?         // cm
  weight         Int?         // kg

  @@index([firstName, lastName])
}

model Parent {
  id                    String       @id @default(cuid())
  registrationId        String       @unique
  registration          Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  primaryName           String
  primaryRelationship   String
  primaryPhone          String
  primaryEmail          String
  secondaryName         String?
  secondaryPhone        String?
  secondaryRelationship String?
  subCity               String
  district              String
  houseNumber           String?
}

model MedicalInfo {
  id             String       @id @default(cuid())
  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  allergies      String?
  conditions     String?
  dietary        String?
}

model Waiver {
  id               String       @id @default(cuid())
  registrationId   String       @unique
  registration     Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  liabilityRelease Boolean
  mediaRelease     Boolean
  parentSignature  String
  dateSigned       DateTime     @default(now())
}

model AuditLog {
  id             String        @id @default(cuid())
  action         String
  performedBy    String?
  registrationId String?
  details        Json?
  createdAt      DateTime      @default(now())

  user           User?         @relation(fields: [performedBy], references: [id])
  registration   Registration? @relation(fields: [registrationId], references: [id])

  @@index([registrationId])
  @@index([performedBy])
}
