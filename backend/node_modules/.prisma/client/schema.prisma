generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("STAFF") // ADMIN, STAFF
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Registration {
  id              String   @id @default(cuid())
  referenceNumber String   @unique
  status          String   @default("PENDING_PAYMENT") // PENDING_PAYMENT, RECEIPT_UPLOADED, UNDER_REVIEW, APPROVED, REJECTED
  session         String // HALF_DAY, FULL_DAY
  amount          Decimal
  receiptUrl      String?
  adminNote       String?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  camper      Camper?
  parent      Parent?
  medicalInfo MedicalInfo?
  waiver      Waiver?
}

model Camper {
  id             String       @id @default(cuid())
  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  dateOfBirth    DateTime
  gender         String
  gradeLevel     String
  schoolName     String
  tShirtSize     String // YOUTH_S, YOUTH_M, YOUTH_L
}

model Parent {
  id                    String       @id @default(cuid())
  registrationId        String       @unique
  registration          Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  primaryName           String
  primaryRelationship   String
  primaryPhone          String
  primaryEmail          String
  secondaryName         String?
  secondaryPhone        String?
  secondaryRelationship String?
  subCity               String
  district              String
  houseNumber           String?
}

model MedicalInfo {
  id             String       @id @default(cuid())
  registrationId String       @unique
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  allergies      String?
  conditions     String?
  dietary        String?
}

model Waiver {
  id               String       @id @default(cuid())
  registrationId   String       @unique
  registration     Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  liabilityRelease Boolean
  mediaRelease     Boolean
  parentSignature  String
  dateSigned       DateTime     @default(now())
}
